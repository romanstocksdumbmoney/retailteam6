PORT=5000
FRONTEND_PORT=3000
APP_BASE_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# Feature defaults
DEFAULT_PLAN=free
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Stripe billing
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_monthly_pro_price_id
# Optional fallback used when STRIPE_PRICE_ID is not set:
# Stripe Checkout will create an inline recurring monthly line item.
STRIPE_PRO_MONTHLY_PRICE_CENTS=1500
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Data provider placeholders
UNUSUAL_WHALES_API_KEY=your_unusual_whales_api_key
FMP_API_KEY=your_fmp_api_key
ZACKS_API_KEY=your_zacks_api_key
TRADEFEEDS_API_KEY=your_tradefeeds_api_key
